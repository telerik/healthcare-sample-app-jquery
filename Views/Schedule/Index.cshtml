@{
    ViewData["Title"] = "Schedule — Dr. Carter";
    ViewData["ActivePage"] = "Schedule";
}

    <!-- ═══════════════════════════════════════════
         PAGE BODY
    ═══════════════════════════════════════════ -->
    <div class="schedule-body">

        <!-- LEFT — SCHEDULER -->
        <div class="schedule-main">
            <div class="k-card sched-card">                
                <div id="scheduler"></div>
            </div>
        </div>

        <!-- RIGHT — SIDE PANEL -->
        <div class="schedule-side">
            <!-- Today's Tasks -->
            <div class="k-card tasks-card">
                <div class="k-card-header tasks-card-header">
                    <h2 class="k-card-title tasks-card-title">Daily Tasks</h2>
                    <div class="tasks-header-actions">
                        <input id="tasks-search" placeholder="Search daily tasks" />
                        <button id="btn-add-task" class="tasks-add-btn">Add Task</button>
                    </div>
                </div>                
                <div class="k-card-body" id="tasks-list"></div>
            </div>            
        </div>
    </div>

    <!-- ═══════════════════════════════════════════
         DIALOGS
    ═══════════════════════════════════════════ -->

    <!-- Add Task dialog -->
    <div id="add-task-dialog">
        <div class="add-task-form">
            <div class="atf-field">
                <span class="atf-label">Task Name</span>
                <input id="atf-name" name="taskName" required validationMessage="Task name is required." />
                <span class="k-invalid-msg atf-error" data-for="taskName"></span>
            </div>
            <div class="atf-field">
                <span class="atf-label">Priority</span>
                <div id="atf-priority-group"></div>
            </div>
            <div class="atf-field">
                <span class="atf-label">Description</span>
                <textarea id="atf-description"></textarea>
            </div>
        </div>
    </div>

    <!-- View Task dialog -->
    <div id="view-task-dialog">
        <div class="add-task-form">
            <div class="atf-field">
                <span class="atf-label">Task</span>
                <div id="vtf-name" class="vtf-value"></div>
            </div>
            <div class="atf-field">
                <span class="atf-label">Priority</span>
                <span id="vtf-priority-badge"></span>
            </div>
            <div class="atf-field">
                <span class="atf-label">Description</span>
                <div id="vtf-description" class="vtf-description"></div>
            </div>
        </div>
    </div>

    <!-- Appointment detail placeholder (content injected by JS) -->
    <div id="appointment-dialog"></div>

@section Scripts {
    <script src="~/js/schedule.js" asp-append-version="true"></script>
}
