@{
    ViewData["Title"] = "Clinical Analytics — Dr. Carter";
    ViewData["ActivePage"] = "Analytics";
}

    <div class="analytics-wrapper">

    <!-- ═══════════════════════════════════════════
         ANALYTICS BODY
    ═══════════════════════════════════════════ -->
    <div id="analytics-body" class="analytics-body">       

        <!-- Row 1: Vitals Over Time (full width) -->
        <div class="analytics-row">
            <div class="k-card analytics-chart-card">
                <div class="k-card-header chart-header">
                    <div class="chart-title">Vitals Over Time</div>
                    <div class="chart-subtitle">Multi-series tracking of blood pressure, heart rate, SpO<sub>2</sub>, and temperature</div>
                </div>
                <div class="k-card-body">
                    <div id="vitals-chart" style="min-height:300px"></div>
                </div>
            </div>
        </div>

        <!-- Row 2: Alerts Over Time (full width) -->
        <div class="analytics-row">
            <div class="k-card analytics-chart-card">
                <div class="k-card-header chart-header">
                    <div class="chart-title">Alerts Over Time</div>
                    <div class="chart-subtitle">Alert count trend by severity level</div>
                </div>
                <div class="k-card-body">
                    <div id="alerts-column-chart" style="min-height:280px"></div>
                </div>
            </div>
        </div>

        <!-- Row 3: Lab Results Range (full width) -->
        <div class="analytics-row">
            <div class="k-card analytics-chart-card">
                <div class="k-card-header chart-header">
                    <div class="chart-title">Lab Results Range</div>
                    <div class="chart-subtitle">Multi-metric range chart showing latest lab results against optimal ranges</div>
                </div>
                <div class="k-card-body">
                    <div id="labs-charts-container"></div>
                </div>
            </div>
        </div>

        <!-- Row 4: Alerts by Category + Risk Score -->
        <div class="analytics-row analytics-row-2col-equal">

            <div class="k-card analytics-chart-card">
                <div class="k-card-header chart-header">
                    <div class="chart-title">Alerts by Category</div>
                    <div class="chart-subtitle">Distribution of alerts by clinical category</div>
                </div>
                <div class="k-card-body">
                    <div id="alerts-donut-chart" style="min-height:340px"></div>
                </div>
            </div>

            <div class="k-card analytics-chart-card analytics-gauge-card">
                <div class="k-card-header chart-header">
                    <div class="chart-title">Risk Score</div>
                    <div class="chart-subtitle">Patient health risk assessment</div>
                </div>
                <div class="k-card-body">
                <div class="risk-gauge-wrap">
                    <div id="risk-gauge" style="height:220px;width:100%"></div>
                </div>
                <div class="risk-score-legend">
                    <div class="risk-legend-item">
                        <span class="rsl-dot rsl-high"></span>
                        <span class="rsl-label">High Risk</span>
                        <span class="rsl-range">70-100</span>
                    </div>
                    <div class="risk-legend-item">
                        <span class="rsl-dot rsl-medium"></span>
                        <span class="rsl-label">Medium Risk</span>
                        <span class="rsl-range">40–69</span>
                    </div>
                    <div class="risk-legend-item">
                        <span class="rsl-dot rsl-low"></span>
                        <span class="rsl-label">Low Risk</span>
                        <span class="rsl-range">0-39</span>
                    </div>
                </div>
                </div><!-- /.k-card-body -->
            </div><!-- /.k-card.analytics-gauge-card -->

        </div>

    </div>

    </div>

@section Scripts {
    <script src="~/js/analytics.js" asp-append-version="true"></script>
}
