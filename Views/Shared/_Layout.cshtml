<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>

    <base href="~/" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" />
    <!-- Kendo UI Default Theme -->
    <link id="kendo-theme" rel="stylesheet" href="https://kendo.cdn.telerik.com/themes/14.1.0/meridian/meridian-main.css" />  

    <!-- Kendo Theme Variable Overrides -->
    <link rel="stylesheet" href="~/css/kendo-theme-overrides.css" asp-append-version="true" />
    <!-- Custom styles -->
    <link rel="stylesheet" href="~/css/custom.css" asp-append-version="true" />
</head>
<body>

    <!-- ═══════════════════════════════════════════
         APP BAR
    ═══════════════════════════════════════════ -->
    <div id="appbar" class="app-appbar">
        <!-- Logo -->
        <span class="k-appbar-section appbar-logo">
            <img src="~/content/CarePointLogo.png" alt="Logo" class="appbar-logo-img logo-full logo-light" />
            <img src="~/content/CarePointLogoDark.png" alt="Logo" class="appbar-logo-img logo-full logo-dark" />
            <img src="~/content/CarePointLogo-no-text.png" alt="Logo" class="appbar-logo-img logo-compact logo-light" />
            <img src="~/content/CarePointLogoDark-no-text.png" alt="Logo" class="appbar-logo-img logo-compact logo-dark" />
        </span>

        <!-- Separator + Hamburger (mobile only) -->
        <span class="appbar-sep hamburger-sep" aria-hidden="true"></span>
        <button class="hamburger-btn" id="hamburger-btn" title="Menu" aria-label="Open navigation"></button>

        <!-- Nav -->
        <span class="k-appbar-section k-appbar-spacer-center appbar-nav">
            <div id="appbar-nav" data-active-page="@ViewData["ActivePage"]"></div>
        </span>

        <!-- Right section -->
        <span class="k-appbar-section appbar-right">
            <input id="appbar-search" />
            <button class="icon-btn search-icon-btn" id="btn-search-toggle" title="Search">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <path d="M7.333 12.667A5.333 5.333 0 1 0 7.333 2a5.333 5.333 0 0 0 0 10.667ZM14 14l-2.9-2.9" stroke="currentColor" stroke-width="1.33" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </button>
            <button class="icon-btn" id="btn-settings" title="Toggle contrast">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <g clip-path="url(#clip0_settings)">
                        <path d="M5.99992 10.6667C8.57725 10.6667 10.6666 8.57734 10.6666 6.00001C10.6666 3.42268 8.57725 1.33334 5.99992 1.33334C3.42259 1.33334 1.33325 3.42268 1.33325 6.00001C1.33325 8.57734 3.42259 10.6667 5.99992 10.6667Z" stroke="currentColor" stroke-width="1.33" stroke-linecap="round" stroke-linejoin="round"/>
                        <path d="M9.99992 14.6667C12.5772 14.6667 14.6666 12.5773 14.6666 10C14.6666 7.42268 12.5772 5.33334 9.99992 5.33334C7.42259 5.33334 5.33325 7.42268 5.33325 10C5.33325 12.5773 7.42259 14.6667 9.99992 14.6667Z" stroke="currentColor" stroke-width="1.33" stroke-linecap="round" stroke-linejoin="round"/>
                    </g>
                    <defs>
                        <clipPath id="clip0_settings">
                            <rect width="16" height="16" fill="white"/>
                        </clipPath>
                    </defs>
                </svg>
            </button>           
            <span class="notif-wrap">
                <button class="icon-btn" id="notif-btn" title="Notifications">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <path d="M8 2C5.8 2 4 3.8 4 6v3.5L2.5 11h11L12 9.5V6c0-2.2-1.8-4-4-4z" stroke="currentColor" stroke-width="1.33" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
                        <path d="M6.5 13c0 .83.67 1.5 1.5 1.5s1.5-.67 1.5-1.5" stroke="currentColor" stroke-width="1.33" stroke-linecap="round" fill="none"/>
                    </svg>
                </button>
            </span>
            <span class="github-wrap">
                <button class="icon-btn" id="btn-github" title="Get the Source Code">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <path fill-rule="evenodd" clip-rule="evenodd" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
                    </svg>
                </button>
                <div id="github-popup"></div>
            </span>
            <span class="appbar-sep"></span>
            <img class="avatar" id="profile-trigger" src="~/content/profile.jpg" alt="Dr. Carter" title="Profile &amp; Settings" />
        </span>
    </div>

    <!-- ═══════════════════════════════════════════
         PAGE HEADERS — persistent, toggled by PJAX
    ═══════════════════════════════════════════ -->
    <div id="page-headers">
        <!-- Home -->
        <div class="page-header greeting home-greeting" data-page="Home">
            <h1>Good morning, Dr. Carter</h1>
            <p>Today is <span id="today-date"></span></p>
        </div>
        <!-- Patients -->
        <div class="page-header patients-page-header" data-page="Patients">
            <div>
                <h1 class="patients-page-title">Patients</h1>
                <p class="patients-page-sub">Monitor patient trends, vitals, lab results, and risk levels in one place</p>
            </div>
            <div class="patients-header-actions">
                <button id="btn-ai-assistance">AI Assistance</button>
                <button id="btn-export-patients">Export</button>
            </div>
        </div>
        <!-- Analytics -->
        <div class="page-header analytics-page-header" data-page="Analytics">
            <div>
                <h1>Clinical Analytics</h1>
                <p>Patient trends, vitals, lab results, and risk assessment overview</p>
            </div>
            <div class="analytics-header-controls">
                <select id="patient-select"></select>
                <button id="btn-export-analytics">Export</button>
            </div>
        </div>
    </div>

    <div id="page-content" class="page-loading">
        @RenderBody()
    </div>

    <!-- ═══════════════════════════════════════════
         SCRIPTS
    ═══════════════════════════════════════════ -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://kendo.cdn.telerik.com/2026.2.520/js/kendo.all.min.js"></script>
    <script src="~/js/data.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/profile.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
